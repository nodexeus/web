# The base URL for the gRPC-Web API
NEXT_PUBLIC_API_URL=""

# Server-side fallback for the gRPC API URL (used by BFF auth routes)
API_URL=""

# The URL for the MQTT WebSocket server (optional)
NEXT_PUBLIC_MQTT_URL=""

# Stripe publishable key — enables billing UI when set (optional)
NEXT_PUBLIC_STRIPE_KEY="pk_test_stripepublickeygoeshere"

# Git commit SHA — injected automatically by CI, set manually for local testing
NEXT_PUBLIC_SHORT_SHA=""

# Comma-separated list of allowed origin hostnames for API route CSRF protection.
# Required when running behind a reverse proxy (e.g. Cloudflare Tunnels) where
# the Host header may not match the public hostname.
# Example: ALLOWED_ORIGINS="app.dev.nodexeus.com,app.nodexeus.com"
ALLOWED_ORIGINS=""
